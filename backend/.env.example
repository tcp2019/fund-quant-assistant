# Fund Quant Assistant
DATABASE_URL=sqlite:///./fund_quant.db
CORS_ORIGINS=["http://localhost:5173"]

# Data sync schedule
AUTO_SYNC_ENABLED=true
AUTO_SYNC_HOUR=20
AUTO_SYNC_MINUTE=5

# tushare token (optional, for NAV fallback)
TUSHARE_TOKEN=

# LLM — 日常在应用「设置 → AI 信号解读」配置（localStorage，不上传服务端）
# 仅在不使用设置页、直接调后端 API 时才需要填写下列项（可整段留空）
# LLM_API_KEY=
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-v4-flash
