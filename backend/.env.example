# Fund Quant Assistant
DATABASE_URL=sqlite:///./fund_quant.db
CORS_ORIGINS=["http://localhost:5173"]

# Data sync schedule
AUTO_SYNC_ENABLED=true
AUTO_SYNC_HOUR=20
AUTO_SYNC_MINUTE=5

# tushare token (optional, for NAV fallback)
TUSHARE_TOKEN=

# LLM (optional, for AI signal interpretation)
# Supports any OpenAI-compatible API
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
